  (, ((fwd-move-22 rule) $self_p $self_t)
     (active-fwd-budget $budget)
     (decFn $budget $next_budget)
     (fwd-currentLayerFn $budget $current_depth)
     (fwd-nextLayerFn $budget $next_depth)
     (fwd-layer $current_depth (state $c0 $c1 $c2 $c3 $c4 $c5 $c6 $c7 _)))
  (O (guard (fwd-seen (state $c0 $c1 $c2 $c3 $c4 _ $c6 $c7 $c5)) (fwd-seen (state $c0 $c1 $c2 $c3 $c4 _ $c6 $c7 $c5)))
     (guard (fwd-seen (state $c0 $c1 $c2 $c3 $c4 _ $c6 $c7 $c5)) (fwd-layer $next_depth (state $c0 $c1 $c2 $c3 $c4 _ $c6 $c7 $c5)))
     (+ (exec (fwd-move-22) $self_p $self_t))))

((fwd-move-23 rule)
  (, ((fwd-move-23 rule) $self_p $self_t)
     (active-fwd-budget $budget)
     (decFn $budget $next_budget)
     (fwd-currentLayerFn $budget $current_depth)
     (fwd-nextLayerFn $budget $next_depth)
     (fwd-layer $current_depth (state $c0 $c1 $c2 $c3 $c4 $c5 $c6 $c7 _)))
  (O (guard (fwd-seen (state $c0 $c1 $c2 $c3 $c4 $c5 $c6 _ $c7)) (fwd-seen (state $c0 $c1 $c2 $c3 $c4 $c5 $c6 _ $c7)))
     (guard (fwd-seen (state $c0 $c1 $c2 $c3 $c4 $c5 $c6 _ $c7)) (fwd-layer $next_depth (state $c0 $c1 $c2 $c3 $c4 $c5 $c6 _ $c7)))
     (+ (exec (fwd-move-23) $self_p $self_t))))

((fwd-budget-barrier rule)
  (, ((fwd-budget-barrier rule) $self_p $self_t)
     ((fwd-move-00 rule) $m00_p $m00_t)
     ((fwd-move-01 rule) $m01_p $m01_t)
     ((fwd-move-02 rule) $m02_p $m02_t)
     ((fwd-move-03 rule) $m03_p $m03_t)
     ((fwd-move-04 rule) $m04_p $m04_t)
     ((fwd-move-05 rule) $m05_p $m05_t)
     ((fwd-move-06 rule) $m06_p $m06_t)
     ((fwd-move-07 rule) $m07_p $m07_t)
     ((fwd-move-08 rule) $m08_p $m08_t)
     ((fwd-move-09 rule) $m09_p $m09_t)
     ((fwd-move-10 rule) $m10_p $m10_t)
     ((fwd-move-11 rule) $m11_p $m11_t)
     ((fwd-move-12 rule) $m12_p $m12_t)
     ((fwd-move-13 rule) $m13_p $m13_t)
     ((fwd-move-14 rule) $m14_p $m14_t)
     ((fwd-move-15 rule) $m15_p $m15_t)
     ((fwd-move-16 rule) $m16_p $m16_t)
     ((fwd-move-17 rule) $m17_p $m17_t)
     ((fwd-move-18 rule) $m18_p $m18_t)
     ((fwd-move-19 rule) $m19_p $m19_t)
     ((fwd-move-20 rule) $m20_p $m20_t)
     ((fwd-move-21 rule) $m21_p $m21_t)
     ((fwd-move-22 rule) $m22_p $m22_t)
     ((fwd-move-23 rule) $m23_p $m23_t)
     (active-fwd-budget $budget)
     (decFn $budget $next_budget))
  (O (- (active-fwd-budget $budget))
     (+ (active-fwd-budget $next_budget))
     (+ (exec (fwd-move-00) $m00_p $m00_t))
     (+ (exec (fwd-move-01) $m01_p $m01_t))
     (+ (exec (fwd-move-02) $m02_p $m02_t))
     (+ (exec (fwd-move-03) $m03_p $m03_t))
     (+ (exec (fwd-move-04) $m04_p $m04_t))
     (+ (exec (fwd-move-05) $m05_p $m05_t))
     (+ (exec (fwd-move-06) $m06_p $m06_t))
     (+ (exec (fwd-move-07) $m07_p $m07_t))
     (+ (exec (fwd-move-08) $m08_p $m08_t))
     (+ (exec (fwd-move-09) $m09_p $m09_t))
     (+ (exec (fwd-move-10) $m10_p $m10_t))
     (+ (exec (fwd-move-11) $m11_p $m11_t))
     (+ (exec (fwd-move-12) $m12_p $m12_t))
     (+ (exec (fwd-move-13) $m13_p $m13_t))
     (+ (exec (fwd-move-14) $m14_p $m14_t))
     (+ (exec (fwd-move-15) $m15_p $m15_t))
     (+ (exec (fwd-move-16) $m16_p $m16_t))
     (+ (exec (fwd-move-17) $m17_p $m17_t))
     (+ (exec (fwd-move-18) $m18_p $m18_t))
     (+ (exec (fwd-move-19) $m19_p $m19_t))
     (+ (exec (fwd-move-20) $m20_p $m20_t))
     (+ (exec (fwd-move-21) $m21_p $m21_t))
     (+ (exec (fwd-move-22) $m22_p $m22_t))
     (+ (exec (fwd-move-23) $m23_p $m23_t))
     (+ (exec (quiesce fwd budget step) $self_p $self_t))))
(exec (init fwd)
      (, (start $seed_state)
         (fwd-depth $depth)
         ((fwd-budget-barrier rule) $barrier_p $barrier_t)
         ((fwd-move-00 rule) $m00_p $m00_t)
         ((fwd-move-01 rule) $m01_p $m01_t)
         ((fwd-move-02 rule) $m02_p $m02_t)
         ((fwd-move-03 rule) $m03_p $m03_t)
         ((fwd-move-04 rule) $m04_p $m04_t)
