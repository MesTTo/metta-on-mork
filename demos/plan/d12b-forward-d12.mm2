         ((fwd-move-08 rule) $m08_p $m08_t)
         ((fwd-move-09 rule) $m09_p $m09_t)
         ((fwd-move-10 rule) $m10_p $m10_t)
         ((fwd-move-11 rule) $m11_p $m11_t)
         ((fwd-move-12 rule) $m12_p $m12_t)
         ((fwd-move-13 rule) $m13_p $m13_t)
         ((fwd-move-14 rule) $m14_p $m14_t)
         ((fwd-move-15 rule) $m15_p $m15_t)
         ((fwd-move-16 rule) $m16_p $m16_t)
         ((fwd-move-17 rule) $m17_p $m17_t)
         ((fwd-move-18 rule) $m18_p $m18_t)
         ((fwd-move-19 rule) $m19_p $m19_t)
         ((fwd-move-20 rule) $m20_p $m20_t)
         ((fwd-move-21 rule) $m21_p $m21_t)
         ((fwd-move-22 rule) $m22_p $m22_t)
         ((fwd-move-23 rule) $m23_p $m23_t))
      (, (fwd-seen $seed_state)
         (fwd-layer 0 $seed_state)
         (active-fwd-budget $depth)
         (exec (fwd-move-00) $m00_p $m00_t)
         (exec (fwd-move-01) $m01_p $m01_t)
         (exec (fwd-move-02) $m02_p $m02_t)
         (exec (fwd-move-03) $m03_p $m03_t)
