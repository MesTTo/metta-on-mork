;; Load decimal <-> Peano numerals and lte from the same ACT tables used by
;; backward-via-forward/bfc-xp.mm2. Run gen-fromNumber.mm2 and gen-lte.mm2 first.
(exec (0)
      (I (ACT fromNumber (fromNumberFn $x $k)))
      (, (fromNumberFn $x $k)
         (toNumberFn $k $x)))

(exec (1)
      (I (ACT lte (lte $k $l))
         (BTM (toNumberFn $k $x))
         (BTM (toNumberFn $l $y)))
      (, (lte $x $y)))

;; Precompute increment and decrement tables for decimal integers.
(exec (1)
      (, (toNumberFn $x $y)
         (toNumberFn (S $x) $sy))
      (, (incFn $y $sy)
         (decFn $sy $y)))

;; addFn A B C means A + B = C for decimal-symbol integers.
;; The table is finite because this experiment uses proof sizes <= 26.
