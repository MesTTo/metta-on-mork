;; Materialized fwd facts computed by fwd-only-hf*.mm2.

(scheduler-fuel (S (S (S (S (S (S (S (S (S (S (S (S (S (S (S Z))))))))))))))))

;; Seed the backward table and install one static scheduler. The Peano fuel lives
;; only in the scheduler exec location; transition rule bodies contain no round
;; constants and are re-emitted byte-identically each cycle.
(exec (2 init)
      (, (target $mps (c: $ta $tx))
         (scheduler-fuel $init_fuel))
      (, (sol $mps 1 (c: (-> $ta $ta) I))
         (solidx (v $mps 1 (-> $ta $ta)))
         (exec (99 $init_fuel)
               (, (exec (99 (S $sched_k)) $sched_ptrn $sched_tplt))
               (, ;; Above the cap, fwd K=1 is the axiom-discharge meet.
                  (exec (30 meet-above-cap)
                        (, (sol $ski $shi (c: (-> $ma $mb) $mf))
                           (gtFn $ski 12)
                           (addFn $meet_remaining 1 $ski)
                           (decFn $shi $meet_h)
                           (lte $meet_h $meet_remaining)
                           (fwd 1 (: $mp $ma)))
                        (O (choose (solidx (v $meet_remaining $meet_h $mb)) (sol $meet_remaining $meet_h (c: $mb ($mf $mp))))
                           (+ (solidx (v $meet_remaining $meet_h $mb)))))
;; At or below the cap, close the tail with any forward theorem that fits.
                  (exec (31 meet-tail)
                        (, (sol $ski $shi (c: (-> $ma $mb) $mf))
                           (lte $ski 12)
                           (lte $mk $ski)
                           (addFn $meet_remaining $mk $ski)
                           (decFn $shi $meet_h)
                           (lte $meet_h $meet_remaining)
                           (fwd $mk (: $mp $ma)))
                        (O (choose (solidx (v $meet_remaining $meet_h $mb)) (sol $meet_remaining $meet_h (c: $mb ($mf $mp))))
                           (+ (solidx (v $meet_remaining $meet_h $mb)))))
;; Backward mpтБ▒ split. Splits stop above the forward cap only.
                  (exec (40 split)
                        (, (sol $ski $hi (c: (-> $b $c) $f))
                           (gtFn $ski 12)
                           (decFn $ski $ki)
                           (lte $hi $ki)
                           (incFn $hi $shi))
                        (O (choose (solidx (v $ki $shi (-> (тЖТ $a $b) (-> $a $c)))) (sol $ki $shi (c: (-> (тЖТ $a $b) (-> $a $c)) (mpтБ▒ $f))))
                           (+ (solidx (v $ki $shi (-> (тЖТ $a $b) (-> $a $c)))))))
;; Completion is the bfc-xp target shape.
                  (exec (50 complete)
                        (, (target $mps (c: $ta $tx))
                           (sol 0 0 (c: $ta $tx)))
                        (, (final 0 0 (c: $ta $tx))))
                  ;; Respawn the same scheduler body with one less fuel tick.
                  (exec (99 $sched_k) $sched_ptrn $sched_tplt)))))
