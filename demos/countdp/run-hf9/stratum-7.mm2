(fwd-count 3 (тЖТ $v0 (тЖТ (тЖТ $v1 (тЖТ $v2 $v3)) (тЖТ (тЖТ $v1 $v2) (тЖТ $v1 $v3)))) s4 1)
(fwd-count 3 (тЖТ $v0 (тЖТ (тЖТ (┬м $v1) (┬м $v2)) (тЖТ $v2 $v1))) s5 1)
(fwd-count 3 (тЖТ (тЖТ $v0 $v1) (тЖТ $v0 $v0)) s6 1)
(fwd-count 3 (тЖТ (тЖТ (тЖТ $v0 (тЖТ $v1 $v2)) (тЖТ $v0 $v1)) (тЖТ (тЖТ $v0 (тЖТ $v1 $v2)) (тЖТ $v0 $v2))) s7 1)
(fwd-count 3 (тЖТ (тЖТ (тЖТ (┬м $v0) (┬м $v1)) $v1) (тЖТ (тЖТ (┬м $v0) (┬м $v1)) $v0)) s8 1)
(fwd-count 5 (тЖТ $v0 $v0) s9 1)
(fwd-count 5 (тЖТ $v0 (тЖТ $v1 $v0)) s10 3)
(fwd-count 5 (тЖТ $v0 (тЖТ $v1 (тЖТ $v2 (тЖТ $v3 $v2)))) s11 1)
(fwd-count 5 (тЖТ $v0 (тЖТ $v1 (тЖТ (тЖТ $v2 (тЖТ $v3 $v4)) (тЖТ (тЖТ $v2 $v3) (тЖТ $v2 $v4))))) s12 1)
(fwd-count 5 (тЖТ $v0 (тЖТ $v1 (тЖТ (тЖТ (┬м $v2) (┬м $v3)) (тЖТ $v3 $v2)))) s13 1)
(fwd-count 5 (тЖТ $v0 (тЖТ (тЖТ $v1 $v2) (тЖТ $v1 $v1))) s14 1)
(fwd-count 5 (тЖТ $v0 (тЖТ (тЖТ (тЖТ $v1 (тЖТ $v2 $v3)) (тЖТ $v1 $v2)) (тЖТ (тЖТ $v1 (тЖТ $v2 $v3)) (тЖТ $v1 $v3)))) s15 1)
(fwd-count 5 (тЖТ $v0 (тЖТ (тЖТ (тЖТ (┬м $v1) (┬м $v2)) $v2) (тЖТ (тЖТ (┬м $v1) (┬м $v2)) $v1))) s16 1)
