(dp-pair 1 5)
(dp-pair 3 3)
(dp-pair 5 1)
(exec (10 contrib)
      (, (dp-pair $i $j)
         (fwd-count $i (тЖТ $fa $fb) $fs $nf)
         (fwd-count $j $fa $xs $nx))
      (O (pure (contrib $fb $i $j $fs $xs $prod) $prod
               (i64_to_string (product_i64 (i64_from_string $nf)
                                           (i64_from_string $nx))))))
