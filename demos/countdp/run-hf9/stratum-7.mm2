;; One DP stratum: contributions to size 7 from pairs i + j + 1 = 7.
(fwd-count 1 (тЖТ $v0 (тЖТ $v1 $v0)) s0 1)
(fwd-count 1 (тЖТ (тЖТ $v0 (тЖТ $v1 $v2)) (тЖТ (тЖТ $v0 $v1) (тЖТ $v0 $v2))) s1 1)
(fwd-count 1 (тЖТ (тЖТ (┬м $v0) (┬м $v1)) (тЖТ $v1 $v0)) s2 1)
