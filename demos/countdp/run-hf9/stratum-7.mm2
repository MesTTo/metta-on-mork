(fwd-count 5 (тЖТ (тЖТ $v0 (тЖТ $v1 $v2)) (тЖТ $v0 (тЖТ $v1 $v2))) s18 1)
(fwd-count 5 (тЖТ (тЖТ $v0 (тЖТ $v1 $v2)) (тЖТ (тЖТ $v0 $v1) (тЖТ $v0 $v2))) s19 3)
(fwd-count 5 (тЖТ (тЖТ $v0 (тЖТ $v1 (тЖТ $v2 $v3))) (тЖТ $v0 (тЖТ (тЖТ $v1 $v2) (тЖТ $v1 $v3)))) s20 1)
(fwd-count 5 (тЖТ (тЖТ $v0 (тЖТ (┬м $v1) (┬м $v2))) (тЖТ $v0 (тЖТ $v2 $v1))) s21 1)
(fwd-count 5 (тЖТ (тЖТ (┬м $v0) (┬м $v1)) (тЖТ $v1 $v0)) s22 3)
