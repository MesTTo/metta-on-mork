(exec 86
  (, (yt $i $v))
  (O (- (yt $i $v))))
; %%END

; %%PHASE P70_CLEAR_PCE_H
(exec 87
  (, (pce h $i $v))
  (O (- (pce h $i $v))))
; %%END

; %%PHASE P70_CLEAR_EH
(exec 88
  (, (eh $i $v))
  (O (- (eh $i $v))))
; %%END

; %%PHASE P70_CLEAR_PCE_Y
(exec 89
  (, (pce y $i $v))
  (O (- (pce y $i $v))))
; %%END

; %%PHASE P70_CLEAR_EY
(exec 90
  (, (ey $i $v))
  (O (- (ey $i $v))))
; %%END

; %%PHASE P71_LOAD_X
(exec 91
  (, (pcupdate $u)
     (pcupdate-sample $u $sample)
     (pcx $sample $i $v))
  (O (+ (pcin x $i $v))
     (+ (pcs x $i $v))
     (+ (pcphi x $i $v))
     (+ (phix $i $v))))
; %%END

; %%PHASE P71_LOAD_Y
(exec 92
  (, (pcupdate $u)
     (pcupdate-sample $u $sample)
     (pcy $sample $i $v))
  (O (+ (pcin y $i $v))
     (+ (yt $i $v))))
; %%END

; %%PHASE P71_RESET_EH
(exec 93
  (, (pczero h $i $z))
  (O (+ (pce h $i $z))
     (+ (eh $i $z))))
; %%END

; %%PHASE P71_RESET_EY
(exec 94
  (, (pczero y $i $z))
  (O (+ (pce y $i $z))
     (+ (ey $i $z))))
; %%END

; %%PHASE P40_EY
(exec 41
  (, (pchp error-lr $lr)
     (pce y $i $old)
     (ey $i $old)
     (gy $i $g))
  (O (- (pce y $i $old))
     (- (ey $i $old))
     (pure (pce y $i $new) $new
           (f32_to_string
             (sub_f32
               (f32_from_string $old)
               (product_f32 (f32_from_string $lr) (f32_from_string $g)))))
     (pure (ey $i $new) $new
           (f32_to_string
             (sub_f32
               (f32_from_string $old)
               (product_f32 (f32_from_string $lr) (f32_from_string $g)))))))
; %%END
